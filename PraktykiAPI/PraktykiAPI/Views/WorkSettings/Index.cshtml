@model IEnumerable<PraktykiAPI.Models.WorkSettings>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.MinWorkdayLengthInMinutes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AutoEndWorkdayLengthInMinutes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MinBreakBetweenWorkdaysInMinutes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MinWorkdayLengthForBreakInMinutes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MinBreakLengthInMinutes)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.MinWorkdayLengthInMinutes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AutoEndWorkdayLengthInMinutes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MinBreakBetweenWorkdaysInMinutes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MinWorkdayLengthForBreakInMinutes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MinBreakLengthInMinutes)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
